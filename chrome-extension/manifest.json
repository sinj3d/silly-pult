{
  "manifest_version": 3,
  "name": "SillyPult Chrome Tracker",
  "version": "0.1.0",
  "description": "Reports active Chrome domains to the local SillyPult helper.",
  "permissions": ["tabs", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:42424/*",
    "http://localhost:42424/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "minimum_chrome_version": "120"
}
